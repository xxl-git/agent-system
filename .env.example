# Agent System 环境变量配置
# 系统环境变量优先；本文件的值作为默认值
# 复制为 .env 后填入实际值

# ─── 云端模型 API Keys ───
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── LM Studio ───
# 本地 LM Studio 服务地址（默认 http://127.0.0.1:1234）
LMSTUDIO_BASE_URL=http://127.0.0.1:1234

# ─── 服务配置 ───
# 监听端口（默认 19701）
PORT=19701
# 运行环境
NODE_ENV=development

# ─── 日志级别 ───
# debug / info / warn / error
LOG_LEVEL=info

# ─── 可选：外部追踪服务 ───
# Sentry DSN（留空则不启用）
SENTRY_DSN=
