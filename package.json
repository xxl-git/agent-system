{
  "name": "agent-system",
  "version": "0.9.2",
  "description": "主动型 Agent 操作系统 — 从零构建",
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "audit": "node dist/audit/audit-server.js",
    "audit-dev": "npx ts-node src/audit/audit-server.ts",
    "admin": "node dist/server/agent-server.js",
    "dry-run": "npx ts-node tests/test-dry-run.ts",
    "server": "node dist/server/agent-server.js",
    "launch": "powershell -File agent.ps1",
    "test": "npx ts-node tests/test-dry-run.ts"
  },
  "dependencies": {
    "@agent-system/core": "*",
    "@agent-system/events": "*",
    "@agent-system/experience": "*",
    "@agent-system/llm": "*",
    "@agent-system/memory": "*",
    "@agent-system/models-core": "*",
    "@agent-system/prompts": "*",
    "@agent-system/resilience": "*",
    "@agent-system/server": "*",
    "@agent-system/skills": "*",
    "@agent-system/tools": "*",
    "chalk": "^5.3.0",
    "js-yaml": "^4.2.0",
    "sql.js": "^1.14.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
