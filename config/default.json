{
  "system": {
    "name": "agent-system",
    "version": "0.9.2"
  },
  "models": {
    "defaultProvider": "lmstudio",
    "providers": {
      "lmstudio": {
        "baseUrl": "http://127.0.0.1:1234/v1",
        "apiKey": "not-needed",
        "model": "qwen/qwen3.5-9b",
        "timeoutMs": 120000,
        "maxTokens": 512
      }
    },
    "customProviders": [
      {
        "id": "deepseek:deepseek-chat",
        "name": "deepseek-chat",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "${DEEPSEEK_API_KEY}",
        "type": "openai",
        "model": "deepseek-chat"
      }
    ]
  },
  "agent": {
    "loopIntervalMs": 1000,
    "heartbeatIntervalMs": 300000,
    "maxSubTasks": 10,
    "defaultTimeoutMs": 600000,
    "callTimeoutMs": 60000,
    "maxRetries": 1,
    "emptyLoopThreshold": 3,
    "debugLogging": false
  },
  "memory": {
    "filePath": "./memory",
    "dbPath": "./data/memory.db",
    "strictRecording": true
  },
  "logging": {
    "level": "debug",
    "dir": "./logs",
    "maxFileSizeMB": 10,
    "maxRotatedFiles": 5
  },
  "context": {
    "maxTokens": 4000,
    "hotWindowSize": 12,
    "summaryTokenBudget": 512,
    "compressionThreshold": 0.75,
    "preserveToolResults": true,
    "preserveSystem": true,
    "attentionEnabled": true
  },
  "model": "qwen3.5-9b-deepseek-v4-flash-mtp",
  "provider": "lmstudio"
}